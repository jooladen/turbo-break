{
  "permissions": {
    "allow": [
      "Bash(pnpm run *)",
      "Bash(pnpm install *)",
      "Bash(pnpm build *)",
      "Bash(pnpm test *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm type-check *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Skill(bkit:plan-plus)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm format -- --write $CLAUDE_TOOL_RESULT_FILE 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
