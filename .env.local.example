# =============================================================
# turbo-break 환경변수 설정
# 이 파일을 .env.local 로 복사 후 값을 채워주세요
# cp .env.local.example .env.local
# =============================================================

# -----------------------------------------------
# Database (bknd 임베디드 백엔드)
# SQLite 파일 경로 (프로덕션에서는 Postgres URL 사용)
# -----------------------------------------------
DATABASE_URL=file:./bknd.db

# -----------------------------------------------
# App Secret (JWT 서명 키)
# 랜덤 문자열: openssl rand -base64 32
# -----------------------------------------------
APP_SECRET=change-this-to-a-random-secret-string

# -----------------------------------------------
# App URL (클라이언트에서 API 호출 시 사용)
# 개발: http://localhost:3000
# 프로덕션: https://your-domain.com
# -----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------
# 시장 데이터 어댑터 선택
# yahoo: Yahoo Finance (15-20분 지연, 인증 불필요)
# kiwoom: 키움 REST API (실시간, API Key + 계좌 필요)
# mock: 합성 데이터 (개발/테스트용, 기본값)
# -----------------------------------------------
MARKET_DATA_ADAPTER=mock

# -----------------------------------------------
# 키움 REST API (MARKET_DATA_ADAPTER=kiwoom 선택 시 필요)
# 공식 사이트: https://openapi.kiwoom.com
# IP 화이트리스트 등록 필수
# -----------------------------------------------
# KIWOOM_API_KEY=your_api_key_here
# KIWOOM_SECRET_KEY=your_secret_key_here
# KIWOOM_API_BASE_URL=https://openapi.kiwoom.com
